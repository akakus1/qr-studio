{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "CommonJS",
    "types": ["node", "express"],
    "lib": ["esnext"],
    "skipLibCheck": true,
    "noEmit": false,
    "outDir": "../dist/api"
  },
  "include": [
    "./**/*",
    "../server/**/*",
    "../shared/**/*",
    "../drizzle/**/*"
  ],
  "exclude": [
    "../node_modules",
    "../**/*.test.ts",
    "../client/**/*"
  ]
}
